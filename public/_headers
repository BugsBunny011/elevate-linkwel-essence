# HTML should always revalidate so users see the latest deploy
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/
  Cache-Control: public, max-age=0, must-revalidate

# Vite emits content-hashed filenames in /assets — safe to cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static media in /public — cache for a week (no hash, but rarely changes)
/*.jpg
  Cache-Control: public, max-age=604800
/*.png
  Cache-Control: public, max-age=604800
/*.svg
  Cache-Control: public, max-age=604800
/*.webp
  Cache-Control: public, max-age=604800
/*.ico
  Cache-Control: public, max-age=604800
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Security headers
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
